    {
      "cell_type": "code",
      "source": [
        "#project\n",
        "\n",
        "import re, random\n",
        "from colorama import Fore, init\n",
        "\n",
        "init(autoreset=True)\n",
        "\n",
        "destinations = {\n",
        "    \"beaches\": [\"Bali\", \"Maldives\", \"Phuket\"],\n",
        "    \"mountains\": [\"Swiss Alps\", \"Rocky Mountains\", \"Himalayas\"],\n",
        "    \"cities\": [\"Tokyo\", \"Paris\", \"New York\"]\n",
        "}\n",
        "jokes = [\n",
        "    \"Why don't programmers like nature? Too many bugs!\",\n",
        "    \"Why did the computer go to the doctor? Because it had a virus!\",\n",
        "    \"Why do travelers always feel warm? Because of all their hot spots!\"\n",
        "]\n",
        "\n",
        "def normalize_input(text):\n",
        "  return re.sub(r\"/s+\", \" \", text.strip().lower())\n",
        "\n",
        "def recommend():\n",
        "  print(Fore.CYAN + \"Travelbot: Beaches, Mountains or Cities? \")\n",
        "  preference = input(Fore.YELLOW + \"You: \")\n",
        "  preference = normalize_input(preference)\n",
        "\n",
        "  if preference in destinations:\n",
        "    suggestion = random.choice(destinations[preference])\n",
        "    print(Fore.GREEN + f\"Travelbot: How about {suggestion}?\")\n",
        "    print(Fore.CYAN + f\"Travelbot: Do you like it? (yes/no)\")\n",
        "    answer = input(Fore.YELLOW + \"You: \").lower()\n",
        "\n",
        "    if answer == \"yes\":\n",
        "      print(Fore.GREEN + f\"Travelbot: Awesome! Enjoy {suggestion}!\")\n",
        "    elif answer == \"no\":\n",
        "      print(Fore.RED + f\"Travelbot: Let's try another.\")\n",
        "      recommend()\n",
        "    else:\n",
        "      print(Fore.RED + f\"Travelbot: I'll suggest again.\")\n",
        "      recommend()\n",
        "  else:\n",
        "    print(Fore.RED + f\"Travelbot: Sorry, I don't have that type of destination.\")\n",
        "\n",
        "    show_help()\n",
        "\n",
        "def packing_tips():\n",
        "  print(Fore.CYAN + \"Travelbot: Where to? \")\n",
        "  location = normalize_input(input(Fore.YELLOW + \"You:  \"))\n",
        "  print(Fore.CYAN + \"Travelbot: How many days: \")\n",
        "  days = input(Fore.YELLOW + \"You:  \")\n",
        "\n",
        "  print(Fore.GREEN + f\"TravelBot: Packing tips for {days} days in {location}:\")\n",
        "  print(Fore.GREEN + \"- Pack versatile clothes.\")\n",
        "  print(Fore.GREEN + \"- Bring chargers/adapters.\")\n",
        "  print(Fore.GREEN + \"- Check the weather forecast.\")\n",
        "\n",
        "def weather_information():\n",
        "    print(Fore.CYAN + \"Travelbot: What type of destination are you travelling to?\")\n",
        "    place = input(Fore.YELLOW + \"You: \")\n",
        "\n",
        "    if place in [\"Bali\", \"Maldives\", \"Phuket\"]:\n",
        "        print(Fore.CYAN + \"The weather tends to be hot in these type of destinations.\")\n",
        "    elif place in [\"Swiss Alps\", \"Rocky Mountains\", \"Himalayas\"]:\n",
        "        print(Fore.CYAN + \"The weather tends to be cold and windy in these type of destinations.\")\n",
        "    elif place in [\"Tokyo\", \"Paris\", \"New York\"]:\n",
        "        print(Fore.CYAN + \"The weather tends to be mild and varies depending on the season.\")\n",
        "    else:\n",
        "        print(Fore.CYAN + \"I don't have that destination. Please try again.\")\n",
        "\n",
        "def local_times():\n",
        "    print(Fore.CYAN + \"Travelbot: Which destination's local time do you want to know?\")\n",
        "    place = input(Fore.YELLOW + \"You: \")\n",
        "\n",
        "    if place in [\"Bali\", \"Maldives\", \"Phuket\"]:\n",
        "        print(Fore.CYAN + \"The local time is usually GMT+8 to GMT+5 depending on the exact location.\")\n",
        "    elif place in [\"Swiss Alps\", \"Paris\"]:\n",
        "        print(Fore.CYAN + \"The local time is GMT+1.\")\n",
        "    elif place in [\"Tokyo\"]:\n",
        "        print(Fore.CYAN + \"The local time is GMT+9.\")\n",
        "    elif place in [\"New York\"]:\n",
        "        print(Fore.CYAN + \"The local time is GMT-5.\")\n",
        "    else:\n",
        "        print(Fore.CYAN + \"I don't have that destination. Please try again.\")\n",
        "\n",
        "def news_updates():\n",
        "    print(Fore.CYAN + \"Travelbot: Which destination do you want news updates for?\")\n",
        "    place = input(Fore.YELLOW + \"You: \")\n",
        "\n",
        "    if place in [\"Bali\", \"Maldives\", \"Phuket\"]:\n",
        "        print(Fore.CYAN + \"These destinations are popular tourist spots. Check for travel advisories and weather updates.\")\n",
        "    elif place in [\"Swiss Alps\", \"Rocky Mountains\", \"Himalayas\"]:\n",
        "        print(Fore.CYAN + \"Mountain regions may have weather warnings or travel restrictions.\")\n",
        "    elif place in [\"Tokyo\", \"Paris\", \"New York\"]:\n",
        "        print(Fore.CYAN + \"These major cities frequently have news updates. Check local news for events and safety information.\")\n",
        "    else:\n",
        "        print(Fore.CYAN + \"I don't have news updates for that destination. Please try again.\")\n",
        "\n",
        "def tell_joke():\n",
        "  print(Fore.YELLOW + f\"Travelbot: {random.choice(jokes)}\")\n",
        "\n",
        "def show_help():\n",
        "    print(Fore.MAGENTA + \"\\nI can:\")\n",
        "    print(Fore.GREEN + \"- Suggest travel spots (say 'recommendation')\")\n",
        "    print(Fore.GREEN + \"- Offer packing tips (say 'packing')\")\n",
        "    print(Fore.GREEN + \"- Tell a joke (say 'joke')\")\n",
        "    print(Fore.CYAN + \"Type 'exit' or 'bye' to end.\\n\")\n",
        "\n",
        "\n",
        "def chat():\n",
        "  print(Fore.CYAN + \"Hello! I'm Travelbot.\")\n",
        "  name = input(Fore.Cyan + \"Your name: \")\n",
        "  print(Fore.Green + f\"Nice to meet you, {name}!\")\n",
        "\n",
        "  show_help()\n",
        "\n",
        "  while True:\n",
        "    user_input = input(Fore.YELLOW + f\"{name}:\" )\n",
        "    user_input = normalize_input(user_input)\n",
        "\n",
        "    if \"recommend\" in user_input or \"suggest\" in user_input:\n",
        "      recommend()\n",
        "    elif \"pack\" in user_input or \"packing\" in user_input:\n",
        "      packing_tips()\n",
        "    elif \"jokes\" in user_input or \"funny\" in user_input:\n",
        "      tell_joke()\n",
        "    elif \"help\" in user_input:\n",
        "      show_help()\n",
        "    elif \"local\" in user_input or \"times\" in user_input:\n",
        "      local_times()\n",
        "    elif \"news\" in user_input:\n",
        "      news_updates()\n",
        "    elif \"weather\" in user_input or \"weather information\" in user_input:\n",
        "      weather_information()\n",
        "    elif \"exit\" in user_input or \"bye\" in user_input:\n",
        "      print(Fore.CYAN + \"Travelbot: Safe Travels, Bye!\")\n",
        "      break\n",
        "    else:\n",
        "      print(Fore.RED + \"Travelbot: Could you rephrase?\")\n",
        "\n",
        "  if __name__ == \"__main__\":\n",
        "    chat()\n",
        "\n",
        "\n"
      ],
