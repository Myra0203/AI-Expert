        "#Extra Project\n",
        "import re, random\n",
        "from colorama import Fore, init\n",
        "\n",
        "init(autoreset=True)\n",
        "\n",
        "books = {\n",
        "    \"Thriller\": [\"The Reappearance of Rachel Price by Holly Jackson\", \"The Housemaid by Fieda McFadden\", \"Five Survive by Holly Jackson \"],\n",
        "    \"Dystopian\": [\"Hunger Games by Suzanne Collins\", \"Maze runner by James Dashner\", \"Shatter Me by Tahereh Mafi\"],\n",
        "    \"Mystery\": [\"The Naturals by Jennifer Lynn Barnes\", \"The Inheritance Games by Jennifer Lynn Barnes\", \"A Good Girl's Guide to Murder by Holly Jackson\"]\n",
        "}\n",
        "\n",
        "def normalize_input(text):\n",
        "  return re.sub(r\"/s+\", \" \", text.strip().lower())\n",
        "\n",
        "def recommend():\n",
        "  print(Fore.CYAN + \"Bookbot: What genre of books are you looking for? Thriller, Dystopian or mustery \")\n",
        "  preference = input(Fore.YELLOW + \"You: \")\n",
        "  preference = normalize_input(preference)\n",
        "\n",
        "\n",
        "  if preference in genre:\n",
        "    suggestion = random.choice(genre[preference])\n",
        "    print(Fore.GREEN + f\"Bookbot: How about {suggestion}?\")\n",
        "    print(Fore.CYAN + f\"Bookbot: Do you like it? (yes/no)\")\n",
        "    answer = input(Fore.YELLOW + \"You: \").lower()\n",
        "\n",
        "    if answer == \"yes\":\n",
        "      print(Fore.GREEN + f\"Bookbot: Awesome! Enjoy {suggestion}!\")\n",
        "    elif answer == \"no\":\n",
        "      print(Fore.RED + f\"Bookbot: Let's try another.\")\n",
        "      recommend()\n",
        "    else:\n",
        "      print(Fore.RED + f\"Bookbot: I'll suggest again.\")\n",
        "      recommend()\n",
        "  else:\n",
        "    print(Fore.RED + f\"Bookbot: Sorry, I don't have that type of genre.\")\n",
        "\n",
        "    show_help()\n",
        "\n",
        "def reading_tips():\n",
        "  print(Fore.CYAN + \"Bookbot: How many pages? \")\n",
        "  pages = normalize_input(input(Fore.YELLOW + \"You:  \"))\n",
        "\n",
        "  print(Fore.GREEN + f\"Reading: Reading tips tips for {pages}\")\n",
        "  print(Fore.GREEN + \"- Skim for main ideas\")\n",
        "  print(Fore.GREEN + \"- Read in comfortable environments\")\n",
        "  print(Fore.GREEN + \"- Take regular breaks to maintain focus, such as reading for 20-30 minutes, then resting..\")\n",
        "\n",
        "# Display help menu\n",
        "def show_help():\n",
        "    print(Fore.MAGENTA + \"\\nI can:\")\n",
        "    print(Fore.GREEN + \"- Suggest book recommendations (say 'recommendation')\")\n",
        "    print(Fore.GREEN + \"- Offer reading tips (say 'reading')\")\n",
        "    print(Fore.CYAN + \"Type 'exit' or 'bye' to end.\\n\")\n",
        "\n",
        "\n",
        "def chat():\n",
        "  print(Fore.CYAN + \"Hello! I'm Bookbot.\")\n",
        "  name = input(Fore.Cyan + \"Your name: \")\n",
        "  print(Fore.Green + f\"Nice to meet you, {name}!\")\n",
        "\n",
        "  show_help()\n",
        "\n",
        "  while True:\n",
        "    user_input = input(Fore.YELLOW + f\"{name}:\" )\n",
        "    user_input = normalize_input(user_input)\n",
        "\n",
        "    if \"recommend\" in user_input or \"suggest\" in user_input:\n",
        "      recommend()\n",
        "    elif \"reading\" in user_input or \"tips\" in user_input:\n",
        "      reading_tips()\n",
        "    elif \"help\" in user_input:\n",
        "      show_help()\n",
        "    elif \"exit\" in user_input or \"bye\" in user_input:\n",
        "      print(Fore.CYAN + \"Bookbot: Enjoy your book, Bye!\")\n",
        "      break\n",
        "    else:\n",
        "      print(Fore.RED + \"Bookbot: Could you rephrase?\")\n",
        "\n",
        "  if __name__ == \"__main__\":\n",
        "    chat()\n",
        "\n",
        "\n"
      ],
